# 复制为 .env 后由 docker compose 自动读取。所有项均可选，未填则用默认值。

# 管理接口鉴权 token（/admin/* 与 GUI 数据接口）。留空则管理接口禁用，仅公开接口可用。
ADMIN_TOKEN=

# 宿主机暴露端口（容器内固定 12346/12347）。
GAME_PORT=12346
HTTP_PORT=12347

# 日志级别：DEBU / INFO / MARK / WARN / ERRO（兼容旧名 DEBUG / ERROR）
LOG_LEVEL=INFO

# 输出语言：zh-CN / en-US / zh-TW / ja-JP / ko-KR / ru-RU
PHIRA_MP_LANG=zh-CN

# 单房间最大人数
ROOM_MAX_USERS=512

# 可选 Agent。保持 disabled 只运行核心服务；启用时改为 unix:///data/agent.sock，
# 将 AGENT_CONFIG_FILE 指向实际配置，并使用 agent profile：
# docker compose --profile agent up -d --build
AGENT_IPC_ENDPOINT=disabled
# 示例文件中的扩展默认全部关闭；正式启用前复制并按需编辑。
AGENT_CONFIG_FILE=./config.example/agent.yaml

# 时区（影响日志时间戳）
TZ=Asia/Shanghai

# 注入构建版本号（可选，留空走内嵌 VERSION）。例：VERSION=$(git describe --tags --always)
VERSION=
