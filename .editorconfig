root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4

[{*.yml,*.yaml,*.json,*.md,*.html,*.css,*.js}]
indent_style = space
indent_size = 2

[{*.sh,Dockerfile}]
indent_style = space
indent_size = 2

[*.ps1]
indent_style = space
indent_size = 4

[License]
trim_trailing_whitespace = false
